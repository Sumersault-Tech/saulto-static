  { icon: "trending_up",  label: "Pipeline Health",  value: "84%",      sub: "+6 pts vs last quarter", w: 126, opacity: 0.48, left: -10,  top: 72,  delay: 0.05, fx: -3, fy: 8,  fdur: 4.2 },
  { icon: "target",       label: "Pace Score",       value: "87",       sub: "Above benchmark",        w: 118, opacity: 0.46, left: 268, top: 148, delay: 0.12, fx: 4,  fy: 7,  fdur: 3.6 },
  { icon: "check_circle", label: "Board Readiness",  value: "96/100",   sub: "up 8 pts",               w: 122, opacity: 0.41, left: -6,  top: 608, delay: 0.18, fx: -3, fy: 9,  fdur: 4.8 },
  { icon: "users",        label: "Rev Forecast",     value: "On track", sub: "Q3 on plan",             w: 114, opacity: 0.39, left: 258, top: 680, delay: 0.08, fx: 4,  fy: 7,  fdur: 3.9 },
