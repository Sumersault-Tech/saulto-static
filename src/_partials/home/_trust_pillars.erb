<%# ═══════════════════════════════════════════════════════════════
   TRUST PILLARS — 3 feature cards with icons
   ═══════════════════════════════════════════════════════════════ %>
<section class="py-20 md:py-28" style="background: hsl(155,18%,97%);">
  <div class="max-w-5xl mx-auto px-6 md:px-12">

    <%# Intro text %>
    <div class="mb-12 md:mb-16 reveal" data-controller="reveal">
      <p class="text-base md:text-lg font-light leading-relaxed max-w-2xl" style="color: hsl(155,12%,42%);">
        Before you book time with us, here&rsquo;s what you should know about how we work.
      </p>
    </div>

    <%# Cards — mobile: stacked with divide, desktop: 3-column grid %>
    <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:gap-8">

      <%# Card 1 — Building icon %>
      <div class="py-8 md:py-0 reveal" data-controller="reveal">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: hsla(155,55%,32%,0.1);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(155,55%,32%)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <rect x="4" y="2" width="16" height="20" rx="2" ry="2" />
            <path d="M9 22v-4h6v4" />
            <path d="M8 6h.01" />
            <path d="M16 6h.01" />
            <path d="M12 6h.01" />
            <path d="M12 10h.01" />
            <path d="M12 14h.01" />
            <path d="M16 10h.01" />
            <path d="M16 14h.01" />
            <path d="M8 10h.01" />
            <path d="M8 14h.01" />
          </svg>
        </div>
        <h3 class="font-display font-light text-xl mb-3" style="color: hsl(155,18%,16%);">
          Designed for people who own P&amp;L
        </h3>
        <p class="text-sm leading-relaxed" style="color: hsl(155,12%,42%);">
          Saulto is built for CEOs, COOs, and finance leaders at growth-stage companies. Not analysts. Not data teams. The people who make decisions and need a live answer to &ldquo;are we going to hit the number.&rdquo;
        </p>
      </div>

      <%# Card 2 — Shield icon + SOC 2 badge %>
      <div class="py-8 md:py-0 reveal" data-controller="reveal">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: hsla(155,55%,32%,0.1);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(155,55%,32%)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
          </svg>
        </div>
        <h3 class="font-display font-light text-xl mb-3" style="color: hsl(155,18%,16%);">
          Your data stays yours. Always.
        </h3>
        <div class="inline-flex items-center gap-1.5 rounded-md px-2.5 py-1 mb-3" style="background: hsla(155,55%,32%,0.08); border: 1px solid hsla(155,55%,32%,0.2);">
          <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="hsl(155,55%,32%)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
          <span class="text-[10px] font-bold tracking-[0.12em] uppercase" style="color: hsl(155,55%,32%);">SOC 2 Type II</span>
        </div>
        <p class="text-sm leading-relaxed" style="color: hsl(155,12%,42%);">
          Read-only access to your tools. End-to-end encryption. No data ever leaves your environment without your explicit permission. We&rsquo;re SOC 2 Type II certified.
        </p>
      </div>

      <%# Card 3 — Layers icon %>
      <div class="py-8 md:py-0 reveal" data-controller="reveal">
        <div class="w-12 h-12 rounded-xl flex items-center justify-center mb-5" style="background: hsla(155,55%,32%,0.1);">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="hsl(155,55%,32%)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="12 2 2 7 12 12 22 7 12 2" />
            <polyline points="2 17 12 22 22 17" />
            <polyline points="2 12 12 17 22 12" />
          </svg>
        </div>
        <h3 class="font-display font-light text-xl mb-3" style="color: hsl(155,18%,16%);">
          Live in 14 days. No IT project.
        </h3>
        <p class="text-sm leading-relaxed" style="color: hsl(155,12%,42%);">
          We handle the entire setup. One onboarding session to connect your tools and configure your model. No implementation consultants. No requirements documents. No engineering lift from your team.
        </p>
      </div>

    </div>
  </div>
</section>
