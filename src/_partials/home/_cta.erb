<%# ═══════════════════════════════════════════════════════════════
   CTA — Final call to action
   ═══════════════════════════════════════════════════════════════ %>
<section class="relative py-24 md:py-36 overflow-hidden" style="background: hsl(155,18%,97%);">

  <%# Dot grid %>
  <div class="absolute inset-0 pointer-events-none opacity-40"
       style="background-image: radial-gradient(circle, rgba(0,0,0,0.06) 1px, transparent 1px); background-size: 34px 34px;"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-6 md:px-12 text-center reveal" data-controller="reveal">

    <%# Label %>
    <p class="text-[11px] font-bold tracking-[0.22em] uppercase mb-5" style="color: hsl(155,55%,32%);">
      You&rsquo;re two weeks from knowing.
    </p>

    <%# Heading %>
    <h2 class="font-display font-light leading-[1.08] tracking-tight mb-6"
        style="font-size: clamp(2rem, 4vw, 3.6rem); color: hsl(155,18%,16%);">
      See your trajectory in one session.
    </h2>

    <%# Subtext %>
    <p class="text-base md:text-lg font-light leading-relaxed mb-10 max-w-xl mx-auto" style="color: hsl(155,12%,42%);">
      14 days from first session to live confidence score. No IT project. No setup fee. Just connect your tools and know your number.
    </p>

    <%# Buttons %>
    <div class="flex flex-wrap items-center justify-center gap-4">
      <a href="#book"
         class="inline-flex items-center justify-center rounded-full px-8 py-3.5 text-sm font-bold tracking-wide text-white hover:opacity-90 transition-opacity"
         style="background: hsl(155,18%,16%);">
        See My Number
      </a>
      <a href="#get-started"
         class="inline-flex items-center justify-center rounded-full border px-8 py-3.5 text-sm font-bold tracking-wide hover:border-[hsl(155,18%,16%)] transition-colors"
         style="border-color: hsl(155,14%,90%); color: hsl(155,18%,16%);">
        Get Started
      </a>
    </div>
  </div>
</section>
