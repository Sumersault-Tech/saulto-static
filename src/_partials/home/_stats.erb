<%# ═══════════════════════════════════════════════════════════════
   STATS — 3-column proof points
   ═══════════════════════════════════════════════════════════════ %>
<section class="py-20 md:py-24" style="background: white;">
  <div class="max-w-4xl mx-auto px-6 md:px-12 reveal" data-controller="reveal">

    <%# Label %>
    <p class="text-center text-[11px] font-bold tracking-[0.22em] uppercase mb-12" style="color: hsl(155,12%,42%);">
      What that looks like in practice
    </p>

    <%# 3 columns with divide %>
    <div class="grid grid-cols-1 md:grid-cols-3 divide-y md:divide-y-0 md:divide-x divide-[hsl(155,14%,90%)]">

      <%# Stat 1 %>
      <div class="text-center py-8 md:py-0 md:px-8">
        <p class="font-display font-light leading-none mb-3" style="font-size: clamp(2.8rem, 5vw, 4rem); color: hsl(155,18%,16%);">
          14 days
        </p>
        <p class="text-sm leading-relaxed" style="color: hsl(155,12%,42%);">
          From first session to live confidence score. No IT project. No change management. Just connect and go.
        </p>
      </div>

      <%# Stat 2 %>
      <div class="text-center py-8 md:py-0 md:px-8">
        <p class="font-display font-light leading-none mb-3" style="font-size: clamp(2.8rem, 5vw, 4rem); color: hsl(155,18%,16%);">
          3x
        </p>
        <p class="text-sm leading-relaxed" style="color: hsl(155,12%,42%);">
          Faster time-to-decision. Leaders spend less time reconciling data and more time acting on it.
        </p>
      </div>

      <%# Stat 3 %>
      <div class="text-center py-8 md:py-0 md:px-8">
        <p class="font-display font-light leading-none mb-3" style="font-size: clamp(2.8rem, 5vw, 4rem); color: hsl(155,18%,16%);">
          700+
        </p>
        <p class="text-sm leading-relaxed" style="color: hsl(155,12%,42%);">
          Integrations available. CRM, ERP, HR, project management, marketing tools, and more. All connected automatically.
        </p>
      </div>

    </div>
  </div>
</section>
