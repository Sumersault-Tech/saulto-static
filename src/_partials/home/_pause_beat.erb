<%# ═══════════════════════════════════════════════════════════════
   PAUSE BEAT — Simple dark typographic section
   ═══════════════════════════════════════════════════════════════ %>
<section class="relative py-24 md:py-36" style="background: hsl(155,18%,16%);">

  <%# Dot grid %>
  <div class="absolute inset-0 pointer-events-none opacity-40"
       style="background-image: radial-gradient(circle, rgba(255,255,255,0.045) 1px, transparent 1px); background-size: 34px 34px;"></div>

  <div class="relative z-10 max-w-4xl mx-auto px-6 md:px-12 text-center reveal" data-controller="reveal">
    <p class="font-display font-light text-white leading-[1.15] tracking-tight" style="font-size: clamp(1.8rem, 4vw, 3.6rem);">
      The leadership table finally has what it always needed: <span style="color: hsl(155,48%,58%);">a live answer.</span>
    </p>
  </div>
</section>
