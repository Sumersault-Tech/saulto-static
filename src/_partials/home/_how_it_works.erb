<%# ═══════════════════════════════════════════════════════════════
   HOW IT WORKS — Three steps. One live answer.
   ═══════════════════════════════════════════════════════════════ %>
<section class="py-20 md:py-28" style="background: hsl(155,18%,97%);">
  <div class="max-w-5xl mx-auto px-6 md:px-12">

    <%# Header %>
    <div class="mb-12 md:mb-16 reveal" data-controller="reveal">
      <p class="text-[11px] font-bold tracking-[0.22em] uppercase mb-4" style="color: hsl(155,55%,32%);">
        How Saulto works
      </p>
      <h2 class="font-display font-light leading-[1.08] tracking-tight"
          style="font-size: clamp(1.8rem, 3.8vw, 3.2rem); color: hsl(155,18%,16%);">
        Three steps. One live answer.
      </h2>
    </div>

    <%# Mobile: horizontal scroll snap carousel %>
    <div class="md:hidden -mx-6 px-6 mb-8">
      <div class="flex gap-4 overflow-x-auto snap-x snap-mandatory pb-4 -mx-2 px-2" style="scrollbar-width: none; -ms-overflow-style: none;">

        <%# Step 01 %>
        <div class="snap-center shrink-0 rounded-2xl border border-[hsl(155,14%,90%)] bg-white p-6" style="width: 82vw; max-width: 320px;">
          <div class="w-11 h-11 rounded-full flex items-center justify-center mb-5" style="background: hsl(155,18%,16%);">
            <span class="font-display text-lg text-white">1</span>
          </div>
          <h3 class="font-display font-light text-2xl mb-3" style="color: hsl(155,18%,16%);">Connect</h3>
          <p class="text-sm leading-relaxed mb-5" style="color: hsl(155,12%,42%);">
            Your tools connect to Saulto. We handle every integration, from CRM to ERP. No engineering effort, no IT project. One session to set up.
          </p>
          <span class="inline-block text-[11px] font-bold tracking-[0.1em] uppercase rounded-full px-3 py-1.5 border border-[hsl(155,14%,90%)]" style="color: hsl(155,18%,16%); background: hsla(155,18%,16%,0.05);">
            One session
          </span>
        </div>

        <%# Step 02 %>
        <div class="snap-center shrink-0 rounded-2xl border border-[hsl(155,14%,90%)] bg-white p-6" style="width: 82vw; max-width: 320px;">
          <div class="w-11 h-11 rounded-full flex items-center justify-center mb-5" style="background: hsl(155,18%,16%);">
            <span class="font-display text-lg text-white">2</span>
          </div>
          <h3 class="font-display font-light text-2xl mb-3" style="color: hsl(155,18%,16%);">Simulate</h3>
          <p class="text-sm leading-relaxed mb-5" style="color: hsl(155,12%,42%);">
            Your live data feeds a simulation engine. 10,000 futures, modeled from your actuals. You get a confidence score across four time horizons, updated continuously.
          </p>
          <span class="inline-block text-[11px] font-bold tracking-[0.1em] uppercase rounded-full px-3 py-1.5 border border-[hsl(155,14%,90%)]" style="color: hsl(155,18%,16%); background: hsla(155,18%,16%,0.05);">
            10,000 futures
          </span>
        </div>

        <%# Step 03 %>
        <div class="snap-center shrink-0 rounded-2xl border border-[hsl(155,14%,90%)] bg-white p-6" style="width: 82vw; max-width: 320px;">
          <div class="w-11 h-11 rounded-full flex items-center justify-center mb-5" style="background: hsl(155,18%,16%);">
            <span class="font-display text-lg text-white">3</span>
          </div>
          <h3 class="font-display font-light text-2xl mb-3" style="color: hsl(155,18%,16%);">Execute</h3>
          <p class="text-sm leading-relaxed mb-5" style="color: hsl(155,12%,42%);">
            Strategic plays are designed, assigned, and tracked weekly. Every initiative ties back to your live confidence score so you always know what&rsquo;s moving the number.
          </p>
          <span class="inline-block text-[11px] font-bold tracking-[0.1em] uppercase rounded-full px-3 py-1.5 border border-[hsl(155,14%,90%)]" style="color: hsl(155,18%,16%); background: hsla(155,18%,16%,0.05);">
            Tracked weekly
          </span>
        </div>
      </div>
    </div>

    <%# Mobile pause moment %>
    <div class="md:hidden mt-4 mb-0">
      <p class="text-sm font-light leading-relaxed" style="color: hsl(155,12%,42%);">
        Your tools built the data. <span class="font-semibold" style="color: hsl(155,18%,16%);">Saulto reads the signal.</span>
      </p>
    </div>

    <%# Desktop: 3-column grid %>
    <div class="hidden md:grid grid-cols-3 gap-0">
      <% [
        { num: "1", title: "Connect", body: "Your tools connect to Saulto. We handle every integration, from CRM to ERP. No engineering effort, no IT project. One session to set up.", tag: "One session" },
        { num: "2", title: "Simulate", body: "Your live data feeds a simulation engine. 10,000 futures, modeled from your actuals. You get a confidence score across four time horizons, updated continuously.", tag: "10,000 futures" },
        { num: "3", title: "Execute", body: "Strategic plays are designed, assigned, and tracked weekly. Every initiative ties back to your live confidence score so you always know what's moving the number.", tag: "Tracked weekly" },
      ].each_with_index do |step, i| %>
        <div class="<%= 'border-l border-[hsl(155,14%,90%)]' if i > 0 %> px-8 reveal" data-controller="reveal">
          <div class="w-11 h-11 rounded-full flex items-center justify-center mb-5" style="background: hsl(155,18%,16%);">
            <span class="font-display text-lg text-white"><%= step[:num] %></span>
          </div>
          <h3 class="font-display font-light text-2xl mb-3" style="color: hsl(155,18%,16%);"><%= step[:title] %></h3>
          <p class="text-sm leading-relaxed mb-5" style="color: hsl(155,12%,42%);">
            <%= step[:body] %>
          </p>
          <span class="inline-block text-[11px] font-bold tracking-[0.1em] uppercase rounded-full px-3 py-1.5 border border-[hsl(155,14%,90%)]" style="color: hsl(155,18%,16%); background: hsla(155,18%,16%,0.05);">
            <%= step[:tag] %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
</section>
