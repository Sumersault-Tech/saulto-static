<%
  gauge_size = 220
  r = (gauge_size / 2.0) * 0.72
  circ = 2 * Math::PI * r
  arc = circ * 0.75
%>
<section class="reveal" data-controller="reveal" style="background: var(--hv2-dark); padding: 100px 24px;">
  <div style="max-width: 960px; margin: 0 auto;">
    <div style="text-align: center; margin-bottom: 56px;">
      <p style="font-family: var(--hv2-sans); font-size: 10px; font-weight: 800; letter-spacing: 0.2em; text-transform: uppercase; color: var(--hv2-gold); margin: 0 0 20px;">The product moment</p>
      <h2 style="font-family: var(--hv2-serif); font-size: clamp(32px, 4vw, 56px); font-weight: 500; color: #fff; line-height: 1.1; margin: 0 0 24px;">
        You ask a question.<br>The engine answers with facts.
      </h2>
      <p style="font-family: var(--hv2-sans); font-size: 17px; color: rgba(255,255,255,0.5); line-height: 1.6; margin: 0 auto; max-width: 520px;">
        Every "what if" question gets a quantified answer. Capacity impact. Financial impact. P&L shift. Trajectory change. All of it, before you commit.
      </p>
    </div>
    <div class="hv2-two-col" style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;">
      <%# Action cards %>
      <div style="display: flex; flex-direction: column; gap: 12px;">
        <p style="font-family: var(--hv2-sans); font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin: 0 0 4px;">Scenario analysis output</p>
        <% [
          { label: "What if we hire a Senior AE for Sales?",        revenue: "+$240K", impact: "+9%",  positive: true },
          { label: "What if we skip the SEO Growth Program?",       revenue: "-$90K",  impact: "-6%",  positive: false },
          { label: "What if we delay the FHIR Integration to Q3?", revenue: "-$60K",  impact: "-4%",  positive: false },
        ].each do |a| %>
          <div style="background: <%= a[:positive] ? 'rgba(30,107,60,0.25)' : 'rgba(176,48,32,0.2)' %>; border: 1.5px solid <%= a[:positive] ? 'rgba(30,107,60,0.4)' : 'rgba(176,48,32,0.35)' %>; border-radius: 14px; padding: 16px 20px;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
              <p style="font-family: var(--hv2-sans); font-size: 13px; font-weight: 700; color: rgba(255,255,255,0.88); margin: 0 0 4px; line-height: 1.3;"><%= a[:label] %></p>
              <span style="font-family: var(--hv2-serif); font-size: 16px; font-weight: 500; color: <%= a[:positive] ? 'var(--hv2-green)' : 'var(--hv2-red)' %>; flex-shrink: 0; margin-left: 12px;"><%= a[:revenue] %></span>
            </div>
            <p style="font-family: var(--hv2-sans); font-size: 12px; color: rgba(255,255,255,0.4); margin: 0;">
              <%= a[:impact] %> trajectory shift
            </p>
          </div>
        <% end %>
      </div>
      <%# Gauge %>
      <div style="display: flex; flex-direction: column; align-items: center; gap: 16px;"
           data-controller="gauge" data-gauge-value-value="87" data-gauge-size-value="<%= gauge_size %>" data-gauge-color-value="var(--hv2-green)">
        <div style="position: relative; width: <%= gauge_size %>px; height: <%= (gauge_size * 0.82).round %>px; flex-shrink: 0;">
          <svg width="<%= gauge_size %>" height="<%= (gauge_size * 0.82).round %>" viewBox="0 0 <%= gauge_size %> <%= (gauge_size * 0.82).round %>">
            <circle cx="<%= gauge_size/2 %>" cy="<%= (gauge_size*0.58).round %>" r="<%= r.round %>" fill="none" stroke="rgba(0,0,0,0.07)" stroke-width="<%= (gauge_size*0.055).round %>"
              stroke-dasharray="<%= arc.round %> <%= (circ - arc).round %>" stroke-dashoffset="<%= (-arc*0.375).round %>" stroke-linecap="round" />
            <circle data-gauge-target="arc" cx="<%= gauge_size/2 %>" cy="<%= (gauge_size*0.58).round %>" r="<%= r.round %>" fill="none" stroke="var(--hv2-green)" stroke-width="<%= (gauge_size*0.055).round %>"
              stroke-dasharray="<%= arc.round %> <%= (circ - arc).round %>" stroke-dashoffset="<%= (-arc*0.375 + arc).round %>" stroke-linecap="round"
              style="transition: stroke-dashoffset 0.04s linear;" />
          </svg>
          <div style="position: absolute; bottom: 2px; left: 0; right: 0; text-align: center;">
            <span data-gauge-target="number" style="font-family: var(--hv2-serif); font-size: <%= (gauge_size * 0.25).round %>px; font-weight: 500; color: var(--hv2-ink); line-height: 1;">0%</span>
          </div>
        </div>
        <div style="text-align: center;">
          <p style="font-family: var(--hv2-sans); font-size: 12px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin: 0 0 6px;">Confidence of hitting annual goal</p>
          <p style="font-family: var(--hv2-sans); font-size: 14px; font-weight: 700; color: var(--hv2-green); margin: 0;">+25% vs. baseline of 62%</p>
        </div>
      </div>
    </div>
  </div>
</section>
