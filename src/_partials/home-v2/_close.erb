<section class="reveal" data-controller="reveal" style="min-height: 80dvh; display: flex; flex-direction: column; align-items: center; justify-content: center; background: var(--hv2-dark); padding: 100px 24px; text-align: center;">
  <p style="font-family: var(--hv2-serif); font-size: clamp(28px, 4vw, 56px); font-weight: 400; color: #fff; line-height: 1.2; margin: 0 0 32px; max-width: 700px;">
    The companies that win don't guess.
  </p>
  <div style="margin-bottom: 56px; max-width: 600px;">
    <p style="font-family: var(--hv2-serif); font-size: clamp(22px, 3vw, 38px); font-weight: 400; color: rgba(255,255,255,0.6); line-height: 1.35; margin: 0 0 20px;">
      They know their number.
    </p>
    <p style="font-family: var(--hv2-serif); font-size: clamp(22px, 3vw, 38px); font-weight: 400; color: rgba(255,255,255,0.6); line-height: 1.35; margin: 0 0 20px;">
      They know what moves it.
    </p>
    <p style="font-family: var(--hv2-serif); font-size: clamp(22px, 3vw, 38px); font-weight: 500; color: var(--hv2-gold); line-height: 1.35; margin: 0;">
