      style="background: var(--hv2-gold); color: var(--hv2-ink); border: none; border-radius: 100px; padding: 16px 44px; font-family: var(--hv2-sans); font-size: 16px; font-weight: 800; cursor: pointer; letter-spacing: 0.03em;">
      Save as PDF
    </button>
    <a href="https://sumersaulttech.com" target="_blank" rel="noopener noreferrer"
      style="font-family: var(--hv2-sans); font-size: 14px; font-weight: 600; color: rgba(255,255,255,0.5); text-decoration: none;">
      sumersaulttech.com
    </a>
    <p style="font-family: var(--hv2-sans); font-size: 12px; color: rgba(255,255,255,0.25); margin: 0;">
      Sumersault Tech LLC &middot; 2026
    </p>
