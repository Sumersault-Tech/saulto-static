<section id="s-diagnosis" class="px-6 py-28 md:py-36" style="border-top: 1px solid var(--pv-border);">
  <div class="max-w-3xl mx-auto">
    <div class="flex items-center gap-3 mb-10 reveal" data-controller="reveal">
      <span style="font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--pv-accent); opacity: 0.75;">03</span>
      <span style="font-size: 0.6rem; letter-spacing: 0.28em; text-transform: uppercase; color: var(--pv-text-dim);">The Diagnosis</span>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-14 items-start">
      <%# Left: copy %>
      <div>
        <div class="reveal" data-controller="reveal">
          <h2 class="font-display font-light" style="font-size: clamp(2rem,4.5vw,3.2rem); color: var(--pv-text); line-height: 1.2; margin-bottom: 1.5rem;">
            What is driving it.<br><span style="color: var(--pv-accent);">Who owns it.</span>
          </h2>
        </div>
        <div class="reveal" data-controller="reveal">
          <p style="font-size: 1.05rem; font-family: 'Inter',sans-serif; font-weight: 300; color: var(--pv-text-mid); line-height: 1.78; margin-bottom: 1.25rem;">
            Saulto decomposes the probability number into its underlying drivers — the specific metrics pulling it in the wrong direction — and assigns each one to the team responsible.
          </p>
        </div>
        <div class="reveal" data-controller="reveal">
          <p style="font-size: 1.05rem; font-family: 'Inter',sans-serif; font-weight: 300; color: var(--pv-text-mid); line-height: 1.78;">
            Click any driver to see the recommended action for that team. The plays are separate from the model — they are guided responses to what the model surfaces.
          </p>
        </div>
      </div>

      <%# Right: expandable cards %>
      <div>
        <div class="inline-flex items-center gap-2 rounded-full px-4 py-2 mb-5" style="background: var(--pv-accent-dim); border: 1px solid var(--pv-accent-border); animation: gentle-bounce 2s ease-in-out infinite;">
          <span style="font-size: 0.9rem; color: var(--pv-accent);">↓</span>
          <span style="font-size: 0.8rem; color: var(--pv-accent); letter-spacing: 0.01em;">Tap any driver to reveal the recommended action</span>
        </div>

        <div class="space-y-3">
          <%
            drivers = [
              {
                driver: "Close rate", delta: "-8pp", team: "Sales",
                detail: "Underperforming vs. historical average",
                action: "Focus senior reps on Segment A, where conversion is 2.3x the company average",
                action_impact: "+8 to 12pp probability",
                hint: "Click to see what Sales should do"
              },
              {
                driver: "Pipeline volume", delta: "-12pp", team: "Marketing",
                detail: "Coverage ratio below 3× target",
                action: "Shift 25% of paid budget to enterprise outbound, where CAC is 40% lower than inbound",
                action_impact: "+6 to 10pp estimated improvement on this driver",
                hint: "Click to see what Marketing should do"
              },
              {
                driver: "Retention rate", delta: "-4pp", team: "Customer Success",
                detail: "Cohort churn rate accelerating",
                action: "Introduce 90-day health score intervention for at-risk accounts, which have 3x higher churn probability",
                action_impact: "+3 to 5pp estimated improvement on this driver",
                hint: "Click to see what Customer Success should do"
              }
            ]
          %>
          <% drivers.each do |r| %>
            <div class="rounded-2xl overflow-hidden cursor-pointer reveal" data-controller="reveal expandable-card" data-action="click->expandable-card#toggle"
                 style="background: var(--pv-surface); border: 1px solid var(--pv-border); transition: background 0.22s, border-color 0.22s;">
              <div class="px-5 py-4">
                <div class="flex items-center justify-between mb-1.5">
                  <p style="font-size: 0.95rem; font-weight: 400; color: var(--pv-text);"><%= r[:driver] %></p>
                  <div class="flex items-center gap-2">
                    <span style="font-size: 0.8rem; color: var(--pv-miss);"><%= r[:delta] %></span>
                    <span class="rounded-md px-2.5 py-0.5" style="font-size: 0.62rem; letter-spacing: 0.1em; color: var(--pv-accent); background: var(--pv-accent-dim); border: 1px solid var(--pv-accent-border); white-space: nowrap;"><%= r[:team] %></span>
                    <span data-expandable-card-target="chevron" style="font-size: 0.85rem; color: var(--pv-text-dim); transition: transform 0.18s;">›</span>
                  </div>
                </div>
                <p style="font-size: 0.75rem; color: var(--pv-text-dim);"><%= r[:hint] %></p>
              </div>
              <div data-expandable-card-target="content" class="pv-expandable-content">
                <div class="px-5 pb-5">
                  <p style="font-size: 0.75rem; color: var(--pv-text-mid); margin-bottom: 0.75rem;"><%= r[:detail] %></p>
                  <div class="rounded-xl px-4 py-3.5" style="background: var(--pv-bg); border: 1px solid var(--pv-accent-border);">
                    <p style="font-size: 0.58rem; letter-spacing: 0.22em; text-transform: uppercase; color: var(--pv-accent); margin-bottom: 0.5rem;">Recommended action</p>
                    <p style="font-size: 0.85rem; font-weight: 400; color: var(--pv-text); line-height: 1.6; margin-bottom: 0.75rem;"><%= r[:action] %></p>
                    <div class="flex items-start gap-2 rounded-lg px-3 py-2.5" style="background: var(--pv-surface); border: 1px solid var(--pv-border);">
                      <span style="font-size: 0.75rem; color: var(--pv-text-dim); line-height: 1;">~</span>
                      <div>
                        <p style="font-size: 0.72rem; color: var(--pv-text-mid); font-weight: 400;"><%= r[:action_impact] %></p>
                        <p style="font-size: 0.62rem; color: var(--pv-text-dim); margin-top: 2px;">Directional estimate — not a model output</p>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</section>
