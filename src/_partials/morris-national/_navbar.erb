<nav style="position: fixed; top: 0; left: 0; right: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; padding: 0 24px; height: 56px; background: rgba(255,255,255,0.93); backdrop-filter: blur(12px); border-bottom: 1px solid var(--mn-border);">
  <img src="<%= relative_url '/images/saulto-logo.png' %>" alt="Saulto" style="height: 24px; filter: brightness(0) saturate(100%) invert(17%) sepia(44%) saturate(700%) hue-rotate(120deg) brightness(85%) contrast(95%);" />
  <span data-morris-national-target="navLabel" style="font-size: 12px; color: var(--mn-muted); font-weight: 600; display: none;"></span>
  <span data-morris-national-target="stepLabel" style="font-size: 12px; color: var(--mn-muted); font-weight: 600; display: none;"></span>
</nav>
