<div data-morris-national-target="phase" data-phase="steps" data-step="4" style="display: none; min-height: 100dvh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 76px 24px 120px; text-align: center;">
  <p style="font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mn-muted); margin-bottom: 26px;">Step 4 of 5</p>

  <%# Visual: Alert %>
  <div style="display: flex; flex-direction: column; gap: 14px; width: 308px; margin-bottom: 28px; text-align: left;">
    <div style="background: var(--mn-warn-l); border: 2px solid var(--mn-warn-b); border-radius: 16px; padding: 20px;">
      <p style="font-size: 10px; font-weight: 800; color: var(--mn-warn); letter-spacing: 0.18em; text-transform: uppercase; margin: 0 0 8px;">Annual goal at risk</p>
      <p style="font-size: 13px; color: var(--mn-text); line-height: 1.55; margin: 0 0 14px;">
        Production is not keeping pace. At current trajectory, Halloween falls short. Your annual goal is at risk.
      </p>
      <div style="display: flex; align-items: baseline; gap: 8px;">
        <span style="font-family: 'Cormorant Garamond', serif; font-size: 44px; font-weight: 500; color: var(--mn-warn); line-height: 1;">$420,000</span>
        <span style="font-size: 13px; color: var(--mn-warn); font-weight: 700;">at risk in your annual number</span>
      </div>
    </div>
  </div>

  <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 7vw, 48px); font-weight: 500; color: var(--mn-text); line-height: 1.1; margin: 0 0 14px; max-width: 480px;">
    Saulto catches it.
  </h2>
  <p style="font-size: clamp(14px, 3.5vw, 17px); color: var(--mn-muted); line-height: 1.7; margin: 0 0 44px; max-width: 420px;">
    Weeks before it becomes a crisis. Your annual goal is at risk. Saulto tells you now, not after you have missed something.
  </p>

  <button data-action="click->morris-national#advance" style="background: var(--mn-accent); color: #fff; border: none; border-radius: 100px; cursor: pointer; padding: 16px 44px; font-size: 15px; font-weight: 700; font-family: 'Inter', sans-serif; letter-spacing: 0.04em;">Continue</button>
  <button data-action="click->morris-national#back" style="margin-top: 14px; background: none; border: none; cursor: pointer; font-size: 13px; color: var(--mn-muted); font-family: 'Inter', sans-serif;">Back</button>
</div>
