<div data-morris-national-target="phase" data-phase="result" style="display: none; min-height: 100dvh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 80px 28px; text-align: center; background: var(--mn-accent); position: relative; overflow: hidden;">
  <div style="position: absolute; inset: 0; pointer-events: none; background: radial-gradient(ellipse at 50% 35%, rgba(255,255,255,0.07) 0%, transparent 65%);"></div>

  <div style="position: relative; z-index: 1; width: 100%; max-width: 560px;">
    <p style="font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-bottom: 22px;">The result</p>

    <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(30px, 7vw, 52px); font-weight: 400; color: #fff; line-height: 1.15; margin: 0 0 22px;">
      You fix problems before retailers feel them.
    </h2>

    <p style="font-size: clamp(17px, 4vw, 22px); color: rgba(255,255,255,0.75); line-height: 1.7; margin: 0 0 38px;">
      No missed shipments.<br>
      No last-minute chaos.<br>
      No surprises.
    </p>

    <%# Before/After strip %>
    <div style="width: 100%; margin-top: 44px;">
      <p style="font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.4); margin-bottom: 18px; text-align: center;">What this means for Morris National</p>
      <div style="display: flex; flex-direction: column; gap: 6px;">
        <% [
          { label: "Shipments",  before: "Delayed to Walmart and Kroger",  after: "Protected on schedule" },
          { label: "Revenue",    before: "$420K at risk",                   after: "Recovered through fast action" },
          { label: "Production", before: "Out of sync with demand",         after: "Realigned to top SKUs" },
          { label: "Retailers",  before: "Risk of missed commitments",      after: "Accounts protected" },
        ].each do |r| %>
          <div style="display: grid; grid-template-columns: 80px 1fr 1fr; gap: 6px; align-items: stretch;">
            <div style="display: flex; align-items: center;">
              <p style="font-size: 10px; font-weight: 700; color: rgba(255,255,255,0.45); margin: 0;"><%= r[:label] %></p>
            </div>
            <div style="background: rgba(255,255,255,0.06); border-radius: 8px; padding: 8px 10px; border: 1px solid rgba(255,255,255,0.08);">
              <p style="font-size: 11px; color: rgba(255,255,255,0.42); margin: 0; line-height: 1.4;"><%= r[:before] %></p>
            </div>
            <div style="background: rgba(255,255,255,0.13); border-radius: 8px; padding: 8px 10px; border: 1px solid rgba(255,255,255,0.22);">
              <p style="font-size: 11px; font-weight: 700; color: #fff; margin: 0; line-height: 1.4;"><%= r[:after] %></p>
            </div>
          </div>
        <% end %>
      </div>
    </div>

    <button data-action="click->morris-national#back"
      style="display: block; margin: 26px auto 0; background: none; border: none; cursor: pointer; font-size: 13px; color: rgba(255,255,255,0.32); font-family: 'Inter', sans-serif;">
      Back
    </button>
  </div>
</div>
