<div data-morris-national-target="phase" data-phase="steps" data-step="1" style="display: none; min-height: 100dvh; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 76px 24px 120px; text-align: center;">
  <p style="font-size: 11px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--mn-muted); margin-bottom: 26px;">Step 1 of 5</p>

  <%# Visual: Metric cards %>
  <div style="display: flex; flex-direction: column; gap: 8px; width: 300px; margin-bottom: 28px; text-align: left;">
    <p style="font-size: 10px; font-weight: 700; letter-spacing: 0.14em; color: var(--mn-muted); text-transform: uppercase; margin: 0 0 4px;">Annual business performance</p>
    <% [
      { label: "Revenue YTD",         value: "$2.1M", note: "+14% YoY" },
      { label: "Core confectionery",  value: "$890K", note: "+11% YoY" },
      { label: "New retail doors",    value: "+18%",  note: "vs. same period last year" },
      { label: "Gross margin",        value: "38%",   note: "stable vs. prior year" },
      { label: "Annual Goal",         value: "$3.2M", note: "66% to target" },
    ].each do |m| %>
      <div style="background: #fff; border: 1.5px solid var(--mn-border); border-radius: 12px; padding: 11px 14px; display: flex; align-items: center; justify-content: space-between; gap: 8px;">
        <p style="font-size: 13px; font-weight: 700; color: var(--mn-text); margin: 0;"><%= m[:label] %></p>
        <div style="display: flex; flex-direction: column; align-items: flex-end;">
          <span style="font-size: 13px; font-weight: 800; color: var(--mn-accent);"><%= m[:value] %></span>
          <span style="font-size: 11px; font-weight: 600; color: #2a7a50;"><%= m[:note] %></span>
        </div>
      </div>
    <% end %>
    <div style="margin-top: 6px; padding: 10px 14px; border-radius: 10px; background: var(--mn-accent-l); border: 1px solid var(--mn-border); text-align: center;">
      <span style="font-size: 12px; font-weight: 700; color: var(--mn-accent);">Saulto reads your accounting data as actuals come in.</span>
    </div>
  </div>

  <h2 style="font-family: 'Cormorant Garamond', serif; font-size: clamp(28px, 7vw, 48px); font-weight: 500; color: var(--mn-text); line-height: 1.1; margin: 0 0 14px; max-width: 480px;">
    Revenue is building. The year is taking shape.
  </h2>
  <p style="font-size: clamp(14px, 3.5vw, 17px); color: var(--mn-muted); line-height: 1.7; margin: 0 0 44px; max-width: 420px;">
    Revenue is running ahead of last year across all channels. Saulto is already tracking your pace against your annual goal from your accounting and CRM data.
  </p>

  <button data-action="click->morris-national#advance" style="background: var(--mn-accent); color: #fff; border: none; border-radius: 100px; cursor: pointer; padding: 16px 44px; font-size: 15px; font-weight: 700; font-family: 'Inter', sans-serif; letter-spacing: 0.04em;">Continue</button>
  <button data-action="click->morris-national#back" style="margin-top: 14px; background: none; border: none; cursor: pointer; font-size: 13px; color: var(--mn-muted); font-family: 'Inter', sans-serif;">Back</button>
</div>
