<div data-progress-dots style="position: fixed; right: 18px; top: 50%; transform: translateY(-50%); display: none; flex-direction: column; gap: 10px; z-index: 50;">
  <% 5.times do |i| %>
    <div data-progress-dot style="width: 7px; height: 7px; border-radius: 50%; background: var(--mn-border); transition: background 0.3s;"></div>
  <% end %>
</div>
