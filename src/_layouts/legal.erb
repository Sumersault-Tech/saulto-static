<!doctype html>
<html lang="<%= site.locale %>">
  <head>
    <%= render "head", metadata: site.metadata, title: data.title %>
  </head>
  <body class="legal min-h-screen bg-background">
    <header class="border-b border-border py-4 px-6 md:px-8">
      <div class="max-w-3xl mx-auto flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors group">
          <svg class="w-4 h-4 group-hover:-translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 12H5M12 19l-7-7 7-7" />
          </svg>
          Back to Saulto
        </a>
        <a href="/">
          <img src="<%= relative_url '/images/saulto-logo.png' %>" alt="Saulto" class="h-7 w-auto" />
        </a>
      </div>
    </header>

    <main class="max-w-3xl mx-auto px-6 md:px-8 py-16 md:py-24">
      <%= yield %>
    </main>

    <footer class="py-8 border-t border-border mt-8">
      <div class="max-w-3xl mx-auto px-6 md:px-8 flex flex-col md:flex-row items-center justify-between gap-3">
        <p class="text-xs text-muted-foreground">&copy; 2026 Sumersault Tech. All rights reserved.</p>
        <div class="flex items-center gap-6">
          <a href="/privacy" class="text-xs text-muted-foreground hover:text-foreground transition-colors">Privacy Policy</a>
          <a href="/terms" class="text-xs text-muted-foreground hover:text-foreground transition-colors">Terms of Service</a>
          <a href="/" class="text-xs text-muted-foreground hover:text-foreground transition-colors">Saulto.com</a>
        </div>
      </div>
    </footer>
  </body>
</html>
